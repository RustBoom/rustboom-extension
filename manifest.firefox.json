{
  "manifest_version": 3,
  "name": "RustBoom Login Helper",
  "version": "0.1.1",
  "description": "Enables Steam login for rustboom.gg by completing the Rust+ companion redirect automatically.",
  "permissions": [
    "declarativeNetRequestWithHostAccess",
    "webRequest",
    "tabs"
  ],
  "host_permissions": [
    "https://companion-rust.facepunch.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "main",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.rustboom.gg/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "rustboom-login@rustboom.gg",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
